generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum RoleUser {
  ADMIN
  GURU
}

enum TipeMedia {
  VIDEO
  PDF
}

enum PeranSiswa {
  SISWA
  KETUA_KELAS
  WAKIL_KETUA
  SEKRETARIS
  BENDAHARA
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String   @map("password_hash")
  role         RoleUser @default(GURU)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}

model Guru {
  id        Int      @id @default(autoincrement())
  nama      String
  posisi    String
  mapel     String
  fotoUrl   String?  @map("foto_url")
  createdAt DateTime @default(now())

  kelas     Kelas[]

  @@map("guru")
}

model Kelas {
  id          Int      @id @default(autoincrement())
  namaKelas   String   @map("nama_kelas")
  waliKelasId Int?     @map("wali_kelas_id")
  deskripsi   String?
  createdAt   DateTime @default(now())

  waliKelas  Guru?    @relation(fields: [waliKelasId], references: [id])
  siswa      Siswa[]

  @@map("kelas")
}

model Siswa {
  id        Int         @id @default(autoincrement())
  nama      String
  peran     PeranSiswa  @default(SISWA)
  fotoUrl   String?     @map("foto_url")
  kelasId   Int         @map("kelas_id")
  createdAt DateTime     @default(now())

  kelas     Kelas       @relation(fields: [kelasId], references: [id])

  @@map("siswa")
}

model MateriElearning {
  id          Int       @id @default(autoincrement())
  judul       String
  tipeMedia   TipeMedia @map("tipe_media")
  linkUrl     String    @map("link_url")
  kelasTarget String    @map("kelas_target")
  createdAt   DateTime  @default(now())

  @@map("materi_elearning")
}

model ArtikelBlog {
  id             Int       @id @default(autoincrement())
  judul          String
  slug           String    @unique
  konten         String    @db.Text
  thumbnailUrl   String?   @map("thumbnail_url")
  tanggalPublish DateTime  @default(now()) @map("tanggal_publish")
  createdAt      DateTime  @default(now())
  kategori       String    @default("Umum")
  isPinned       Boolean   @default(false) @map("is_pinned")

  @@map("artikel_blog")
}

model StatistikSekolah {
  id            Int      @id @default(1)
  totalSiswa    Int      @map("total_siswa")
  totalGuru     Int      @map("total_guru")
  totalKelas    Int      @map("total_kelas")
  totalAlumni   Int      @map("total_alumni")
  updatedAt     DateTime @updatedAt

  @@map("statistik_sekolah")
}

model MitraIndustri {
  id              String   @id @default(cuid())
  namaPerusahaan  String   @map("nama_perusahaan")
  logoUrl         String?  @map("logo_url")
  websiteUrl      String?  @map("website_url")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  lowongan        LowonganKerja[]

  @@map("mitra_industri")
}

model LowonganKerja {
  id              Int       @id @default(autoincrement())
  judul           String
  tipePekerjaan   String    @map("tipe_pekerjaan")
  lokasi          String
  deskripsi       String    @db.Text
  posterUrl       String?   @map("poster_url")
  status          String    @default("BUKA")
  mitraId         String    @map("mitra_id")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  mitra           MitraIndustri @relation(fields: [mitraId], references: [id])

  @@map("lowongan_kerja")
}

model PenempatanAlumni {
  id                  Int      @id @default(autoincrement())
  namaAlumni          String   @map("nama_alumni")
  tahunLulus           Int      @map("tahun_lulus")
  perusahaanTempatKerja String @map("perusahaan_tempat_kerja")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("penempatan_alumni")
}

enum StatusPPDB {
  PENDING
  DITERIMA
  DITOLAK
}

model PPDB {
  id              String      @id @default(uuid())
  namaLengkap     String      @map("nama_lengkap")
  nisn            String      @unique
  asalSekolah     String      @map("asal_sekolah")
  jenisKelamin    String      @map("jenis_kelamin")
  noWA            String      @map("no_wa")
  email           String?
  alamat          String?
  nilaiRata       Float?      @map("nilai_rata")
 JurusanPilihan  String      @map("jurusan_pilihan")
  status          StatusPPDB @default(PENDING)
  catatan         String?     @db.Text
  tanggalDaftar   DateTime    @default(now()) @map("tanggal_daftar")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@map("ppdb")
}
